# OpenAI — Realtime transcription_sessions / 브라우저 WebSocket 에피메랄 토큰 (서버 전용)
OPENAI_API_KEY=your_openai_api_key_here

# (선택) AssemblyAI — 레거시 Provider 테스트·전환용
# ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
# ASSEMBLYAI_STREAMING_API_BASE=https://streaming.eu.assemblyai.com
# (선택) 브라우저 스트리밍 URL·모델 등 — 비밀이 아닌 값만. 자세한 키 이름은 assemblyai Provider 코드 참고.
# NEXT_PUBLIC_ASSEMBLYAI_STREAMING_WS_ORIGIN=
# NEXT_PUBLIC_ASSEMBLYAI_SPEECH_MODEL=
# NEXT_PUBLIC_ASSEMBLYAI_STREAMING_LANGUAGE_DETECTION=

# STT 토큰 API 레이트 리밋 (선택, IP/프록시 키당 — 서버리스에서는 인스턴스별 메모리)
# STT_TOKEN_RATE_LIMIT_MAX=60
# STT_TOKEN_RATE_LIMIT_WINDOW_MS=600000

# 회의록 요약 API (/api/meeting-minutes) 레이트 리밋 (선택, 동일하게 인스턴스별 메모리 한계 있음)
# MEETING_MINUTES_RATE_LIMIT_MAX=40
# MEETING_MINUTES_RATE_LIMIT_WINDOW_MS=600000
